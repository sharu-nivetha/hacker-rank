from collections import defaultdict
n_m = list(map(int, input().split()))
n = n_m[0]
m = n_m[1]
d = defaultdict(list)
for i in range(1, n + 1):
    word = input()
    d[word].append(str(i))
for _ in range(m):
    word = input()
    if word in d:
        print(" ".join(d[word]))
    else:
        print("-1")
